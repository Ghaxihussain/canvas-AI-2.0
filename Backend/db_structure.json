{
  "users": {
    "columns": {
      "id": "uuid PK",
      "name": "string NOT NULL",
      "email": "string NOT NULL UNIQUE",
      "password_hash": "text NOT NULL",
      "is_deleted": "boolean NOT NULL DEFAULT false",
      "created_at": "timestamptz DEFAULT now()"
    }
  },
  "classes": {
    "columns": {
      "id": "uuid PK",
      "name": "string NOT NULL",
      "description": "text",
      "class_code": "string NOT NULL UNIQUE",
      "owner_id": "uuid NOT NULL FK->users.id RESTRICT",
      "created_at": "timestamptz DEFAULT now()"
    }
  },
  "enrollments": {
    "columns": {
      "id": "uuid PK",
      "class_id": "uuid NOT NULL FK->classes.id CASCADE",
      "user_id": "uuid NOT NULL FK->users.id CASCADE",
      "role": "string NOT NULL CHECK(teacher|student)",
      "created_at": "timestamptz DEFAULT now()"
    },
    "constraints": {
      "unique": ["class_id", "user_id"]
    }
  },
  "announcements": {
    "columns": {
      "id": "uuid PK",
      "class_id": "uuid NOT NULL FK->classes.id CASCADE",
      "author_id": "uuid FK->users.id SET NULL",
      "title": "string NOT NULL",
      "content": "text NOT NULL",
      "created_at": "timestamptz DEFAULT now()",
      "updated_at": "timestamptz DEFAULT now()"
    }
  },
  "assignments": {
    "columns": {
      "id": "uuid PK",
      "class_id": "uuid NOT NULL FK->classes.id CASCADE",
      "created_by": "uuid FK->users.id SET NULL",
      "title": "string NOT NULL",
      "text_content": "text",
      "rubric_text_content": "text",
      "assignment_file_url": "text",
      "rubric_file_key": "text",
      "total_grade": "int NOT NULL DEFAULT 100",
      "created_at": "timestamptz DEFAULT now()",
      "updated_at": "timestamptz DEFAULT now()"
    }
  },
  "submissions": {
    "columns": {
      "id": "uuid PK",
      "assignment_id": "uuid NOT NULL FK->assignments.id CASCADE",
      "user_id": "uuid NOT NULL FK->users.id CASCADE",
      "text_content": "text",
      "file_url": "text",
      "graded": "boolean DEFAULT false",
      "grade": "int",
      "feedback": "text",
      "created_at": "timestamptz DEFAULT now()",
      "updated_at": "timestamptz DEFAULT now()"
    },
    "constraints": {
      "unique": ["assignment_id", "user_id"]
    }
  }
}